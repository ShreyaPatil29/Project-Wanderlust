<%layout("./layouts/boilerplate")%>
<body>
<style>
#filters{
    display:flex;
    flex-wrap: wrap;
    align-items: center;
}

.filter{
   text-align: center;
   margin-right: 2rem;
   margin-top: 2rem;
   opacity: 0.7;
}

.active-filter {
      color: red;
      font-weight: bold;
    }

.filter:hover{
    opacity: 1;
    cursor: pointer;
}

.filter p{
    font-size: 0.8rem;
}

/* 🔥 important for link */
.filter a{
    text-decoration: none;
    color: inherit;
    display: inline-block;
}

.tax-info{
    display: none;
}

.tax-toggle{
    border: 1px solid black;
    border-radius: 1rem;
    height: 3.25rem;
    padding: 1rem;
    margin-left: 5rem;
    display: flex;
    align-items: center;
}
</style>

<!-- ✅ ALL FILTERS IN ONE LINE -->
<div id="filters">

    <div class="filter">
        <a href="/listings?category=trending" class="<%= category === 'trending' ? 'active-filter' : '' %>">
            <div><i class="fa-solid fa-fire"></i></div>
            <p>Trending</p>
        </a>
    </div>

    <div class="filter">
        <a href="/listings?category=rooms" class="<%= category === 'rooms' ? 'active-filter' : '' %>">
            <div><i class="fa-solid fa-bed"></i></div>
            <p>Rooms</p>
        </a>
    </div>

    <div class="filter">
        <a href="/listings?category=rooms" class="<%= category === 'iconic' ? 'active-filter' : '' %>">
            <div><i class="fa-solid fa-mountain-city"></i></div>
            <p>Iconic cities</p>
        </a>
    </div>

    <div class="filter">
        <a href="/listings?category=rooms" class="<%= category === 'mountains' ? 'active-filter' : '' %>">
            <div><i class="fa-solid fa-mountain"></i></div>
            <p>Mountains</p>
        </a>
    </div>

    <div class="filter">
        <a href="/listings?category=rooms" class="<%= category === 'castles' ? 'active-filter' : '' %>">
            <div><i class="fa-brands fa-fort-awesome"></i></div>
            <p>Castles</p>
        </a>
    </div>

    <div class="filter">
        <a href="/listings?category=rooms" class="<%= category === 'pools' ? 'active-filter' : '' %>">
            <div><i class="fa-solid fa-person-swimming"></i></div>
            <p>Amazing Pools</p>
        </a>
    </div>

    <div class="filter">
        <a href="/listings?category=rooms" class="<%= category === 'camping' ? 'active-filter' : '' %>">
            <div><i class="fa-solid fa-campground"></i></div>
            <p>Camping</p>
        </a>
    </div>

    <div class="filter">
        <a href="/listings?category=rooms" class="<%= category === 'farms' ? 'active-filter' : '' %>">
            <div><i class="fa-solid fa-cow"></i></div>
            <p>Farms</p>
        </a>
    </div>

    <div class="filter">
        <a href="/listings?category=rooms" class="<%= category === 'arcticrooms' ? 'active-filter' : '' %>">
            <div><i class="fa-regular fa-snowflake"></i></div>
            <p>Arctic</p>
        </a>
    </div>

    <div class="filter">
        <a href="/listings?category=rooms" class="<%= category === 'domes' ? 'active-filter' : '' %>">
            <div><i class="fa-solid fa-igloo"></i></div>
            <p>Domes</p>
        </a>
    </div>

    <div class="filter">
        <a href="/listings?category=rooms" class="<%= category === 'boats' ? 'active-filter' : '' %>">
            <div><i class="fa-solid fa-ship"></i></div>
            <p>Boats</p>
        </a>
    </div>

    <div class="tax-toggle">
        <div class="form-check-reverse form-switch">
            <input class="form-check-input" type="checkbox" id="flexSwitchCheckDefault">
            <label class="form-check-label">Display total after taxes</label>
        </div>
    </div>

</div>

<!-- ✅ LISTINGS -->
<% if(allListings.length === 0){ %>
  <h4 style="text-align:center; margin-top:20px;">
    No listings found 😔
  </h4>
<% } %>
<div class="row row-cols-sm-1 row-cols-md-2 row-cols-lg-3 mt-3">
    <% for(let listing of allListings) { %>
        <a href="/listings/<%= listing._id%>" class="listing-link">
            <div class="card col listing-card">
                <img 
                src="<%= listing.image?.url || listing.image || 'https://via.placeholder.com/400' %>"
                class="card-img-top" 
                style="height: 20rem"
                />
                <div class="card-body">
                    <p class="card-text">
                        <b><%= listing.title %></b><br>
                        ₹ <%= listing.price.toLocaleString("en-IN") %> /night
                        <i class="tax-info"> +18% GST</i>
                    </p>
                </div>
            </div>
        </a>
    <% } %>
</div>

</body>

<script>
let taxSwitch = document.getElementById("flexSwitchCheckDefault");
taxSwitch.addEventListener("click", () => {
    let taxInfo = document.getElementsByClassName("tax-info");
    for(let info of taxInfo){
        info.style.display = (info.style.display !== "inline") ? "inline" : "none";
    }
});
</script>